{
	"common": {
		"name": "alphainnotec",
		"version": "0.0.1",
		"news": {
			"0.0.1": {
				"en": "initial release",
				"de": "Erstveröffentlichung"
			}
		},
		"title": "AlphaInnotec",
		"titleLang": {
			"en": "AlphaInnotec",
			"de": "AlphaInnotec"
		},
		"desc": {
			"en": "Polls Data from AlphaInnotec Heatpump",
			"de": "Fragt Daten von AlphaInnotec Heatpump ab"
		},
		"authors": [
			"Felix Amler <felix@amler.eu>"
		],
		"keywords": [
			"Heatpump",
			"AlphaInnotec",
			"SmartHome"
		],
		"license": "MIT",
		"platform": "Javascript/Node.js",
		"main": "main.js",
		"icon": "alphainnotec.png",
		"enabled": true,
		"extIcon": "https://raw.githubusercontent.com/Net-Felix/ioBroker.alphainnotec/main/admin/alphainnotec.png",
		"readme": "https://github.com/Net-Felix/ioBroker.alphainnotec/blob/main/README.md",
		"loglevel": "info",
		"mode": "daemon",
		"type": "iot-systems",
		"compact": true,
		"connectionType": "local",
		"dataSource": "poll",
		"materialize": true,
		"eraseOnUpload": true,
		"dependencies": [
			{
				"js-controller": ">=2.0.0"
			}
		]
	},
	"native": {
		"password": "0000",
		"port": 8214,
		"polltime": 30,
		"ipaddress": ""
	},
	"objects": [],
	"instanceObjects": [
		{
			"_id": "info",
			"type": "channel",
			"common": {
				"name": "Information"
			},
			"native": {}
		},
		{
			"_id": "info.connection",
			"type": "state",
			"common": {
				"role": "indicator.connected",
				"name": "Device or service connected",
				"type": "boolean",
				"read": true,
				"write": false,
				"def": false
			},
			"native": {}
		}
	]
}